generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  city          String?
  country       String?
  bio           String?
  password      String?
  phone         String?
  avatarUrl     String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  trips         Trip[]
  tripNotes     TripNote[]
  communityPosts CommunityPost[]
  likes         Like[]
  comments      Comment[]
  passwordResetToken PasswordResetToken?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model City {
  id          String   @id @default(cuid())
  name        String
  country     String
  region      String
  imageUrl    String?
  description String?
  costIndex   Int      @default(3)
  popularity  Int      @default(0)
  globalActivities GlobalActivity[]
  createdAt   DateTime @default(now())
}

model GlobalActivity {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  imageUrl    String?
  averageCost Float    @default(0)
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])
  createdAt   DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  userId  String   @unique
  token   String   @unique
  expires DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trip {
  id           String   @id @default(cuid())
  title        String
  description  String?
  coverUrl     String?
  startDate    DateTime
  endDate      DateTime
  isPublic     Boolean  @default(false)
  isTemplate   Boolean  @default(false)
  totalBudget  Float?
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  stops        Stop[]
  notes        TripNote[]
  expenses     Expense[]
  checklist    ChecklistItem[]
  communityPosts CommunityPost[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Stop {
  id         String     @id @default(cuid())
  cityName   String
  country    String
  latitude   Float?
  longitude  Float?
  startDate  DateTime
  endDate    DateTime
  order      Int
  budget     Float?
  tripId     String
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]
  expenses   Expense[]
  notes      TripNote[]
}

model Activity {
  id          String    @id @default(cuid())
  name        String
  category    String
  description String?
  imageUrl    String?
  cost        Float     @default(0)
  expense     Float     @default(0)
  intensity   String    @default("Low") // Low, Medium, High
  duration    Int?
  scheduledAt DateTime?
  stopId      String
  stop        Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(cuid())
  category    String
  description String
  quantity    Int       @default(1)
  unitCost    Float
  amount      Float
  date        DateTime?
  stopId      String?
  stop        Stop?     @relation(fields: [stopId], references: [id], onDelete: SetNull)
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripNote {
  id        String   @id @default(cuid())
  content   String
  day       Int?
  stopId    String?
  stop      Stop?    @relation(fields: [stopId], references: [id], onDelete: SetNull)
  tripId    String
  userId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ChecklistItem {
  id       String  @id @default(cuid())
  label    String
  category String
  isPacked Boolean @default(false)
  tripId   String
  trip     Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  likesCount Int      @default(0)
  likes      Like[]
  comments   Comment[]
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  userId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
